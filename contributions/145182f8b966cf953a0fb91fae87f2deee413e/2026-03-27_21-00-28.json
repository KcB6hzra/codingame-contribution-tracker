      "solution": "#include <stdlib.h>\n#include <stdio.h>\n#include <string.h>\n#include <stdbool.h>\n\n/**\n * Auto-generated code below aims at helping you parse\n * the standard input according to the problem statement.\n **/\n\nint main()\n{\n    int N;\n    scanf(\"%d\", &N); fgetc(stdin);\n\n    char S[26] = \"\";\n    scanf(\"%[^\\n]\", S); fgetc(stdin);\n\n    int M;\n    scanf(\"%d\", &M);\n\n    int positions[N];\n    char *token = strtok(S, \" \");\n    for (int i = 0; i < N && token != NULL; i++) {\n        positions[i] = atoi(token);\n        token = strtok(NULL, \" \");\n    }\n\n    bool possible = true;\n    for (int i = 1; i < N; i++) {\n        if (positions[i] - positions[i-1] > M) {\n            possible = false;\n            break;\n        }\n    }\n\n    printf(\"%s\\n\", possible ? \"YES\" : \"NO\");\n\n    return 0;\n}",
