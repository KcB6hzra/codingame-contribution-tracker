      "shortest": false,
      "solution": "#include <stdio.h>\n#include <string.h>\n\n#define OFFSET 200000\n\nint main() {\n    char s[200005];\n    scanf(\"%s\", s);\n\n    int n = strlen(s);\n    static int firstIndex[400001];\n\n    for (int i = 0; i <= 2 * OFFSET; i++)\n        firstIndex[i] = -2;\n\n    int sum = 0;\n    int maxLen = 0;\n    firstIndex[OFFSET] = -1;\n\n    for (int i = 0; i < n; i++) {\n        sum += (s[i] == '1') ? 1 : -1;\n\n        int idx = sum + OFFSET;\n        if (firstIndex[idx] >= -1) {\n            int len = i - firstIndex[idx];\n            if (len > maxLen)\n                maxLen = len;\n        } else {\n            firstIndex[idx] = i;\n        }\n    }\n\n    printf(\"%d\\n\", maxLen);\n    return 0;\n}\n",
