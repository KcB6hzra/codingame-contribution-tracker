      "solution": "#include <stdio.h>\n#include <string.h>\n\nint main() {\n    char gate[10];\n    int a, b;\n    scanf(\"%s\", gate);\n    scanf(\"%d %d\", &a, &b);\n\n    int result;\n\n    if (strcmp(gate, \"AND\") == 0)       result = a & b;\n    else if (strcmp(gate, \"OR\") == 0)   result = a | b;\n    else if (strcmp(gate, \"XOR\") == 0)  result = a ^ b;\n    else if (strcmp(gate, \"NAND\") == 0) result = !(a & b);\n    else if (strcmp(gate, \"NOR\") == 0)  result = !(a | b);\n    else if (strcmp(gate, \"XNOR\") == 0) result = !(a ^ b);\n    else result = 0;\n\n    printf(\"%d\", result ? 1 : 0);\n    return 0;\n}",
