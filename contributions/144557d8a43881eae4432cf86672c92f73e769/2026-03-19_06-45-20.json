      "solution": "use std::io;\nuse std::collections::VecDeque;\n\nfn main() {\n    let mut input = String::new();\n    io::stdin().read_line(&mut input).unwrap();\n    let mut iter = input.trim().split_whitespace();\n    let w: usize = iter.next().unwrap().parse().unwrap();\n    let h: usize = iter.next().unwrap().parse().unwrap();\n\n    let mut grid: Vec<Vec<u8>> = Vec::with_capacity(h);\n    for _ in 0..h {\n        let mut line = String::new();\n        io::stdin().read_line(&mut line).unwrap();\n        grid.push(line.trim().bytes().collect());\n    }\n\n    eprintln!(\"Grid: {}x{}\", w, h);\n\n    let mut visited = vec![vec![false; w]; h];\n\n    // Flood-fill from all border '.' cells to mark exterior\n    let mut queue = VecDeque::new();\n    for r in 0..h {\n        for c in 0..w {\n            if (r == 0 || r == h - 1 || c == 0 || c == w - 1) && grid[r][c] == b'.' {\n                if !visited[r][c] {\n                    visited[r][c] = true;\n                    queue.push_back((r, c));\n                }\n            }\n        }\n    }\n\n    // BFS to mark all exterior '.' cells\n    while let Some((r, c)) = queue.pop_front() {\n        for (dr, dc) in [(!0usize, 0), (1, 0), (0, !0usize), (0, 1)] {\n            let nr = r.wrapping_add(dr);\n            let nc = c.wrapping_add(dc);\n            if nr < h && nc < w && !visited[nr][nc] && grid[nr][nc] == b'.' {\n                visited[nr][nc] = true;\n                queue.push_back((nr, nc));\n            }\n        }\n    }\n\n    // Count remaining unvisited '.' components = holes\n    let mut holes = 0;\n    for r in 0..h {\n        for c in 0..w {\n            if !visited[r][c] && grid[r][c] == b'.' {\n                holes += 1;\n                eprintln!(\"Hole found at ({}, {})\", c, r);\n                // BFS to mark this hole\n                visited[r][c] = true;\n                queue.push_back((r, c));\n                while let Some((rr, cc)) = queue.pop_front() {\n                    for (dr, dc) in [(!0usize, 0), (1, 0), (0, !0usize), (0, 1)] {\n                        let nr = rr.wrapping_add(dr);\n                        let nc = cc.wrapping_add(dc);\n                        if nr < h && nc < w && !visited[nr][nc] && grid[nr][nc] == b'.' {\n                            visited[nr][nc] = true;\n                            queue.push_back((nr, nc));\n                        }\n                    }\n                }\n            }\n        }\n    }\n\n    eprintln!(\"Total holes: {}\", holes);\n    println!(\"{}\", holes);\n}\n",
      "statement": "You are given a 2D grid where {{#}} represents solid material and {{.}} represents empty space.\n\nEmpty space is connected using <<4-connectivity>> (up, down, left, right; diagonals do not count).\n\nA <<hole>> is a connected region of {{.}} that does not touch the border of the grid.\n\nYour task is to count the number of holes in the grid.",
