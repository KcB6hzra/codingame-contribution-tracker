      "solution": "n = int(input().strip())\nnumbers = list(map(int, input().split()))\n\neven_count = 0\nodd_count = 0\n\nfor x in numbers:\n    if x % 2 == 0:\n        even_count += 1\n    else:\n        odd_count += 1\n\nprint(\"Even:\", even_count)\nprint(\"Odd:\", odd_count)",
