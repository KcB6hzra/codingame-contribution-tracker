      "solution": "using System;\n\nclass Solution\n{\n    static void Main()\n    {\n        int n = int.Parse(Console.ReadLine());\n        long value = 0;\n\n        for (int i = 0; i < n; i++)\n        {\n            string op = Console.ReadLine().Trim();\n            value += long.Parse(op);\n        }\n\n        Console.WriteLine(value);\n    }\n}",
