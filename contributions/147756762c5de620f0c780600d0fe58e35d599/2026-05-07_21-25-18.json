      "solution": "#include <stdio.h>\n#include <ctype.h>\n\nint main(void)\n{\n    char s[1000];\n    int i = 0, res = 0;\n\n    if (!fgets(s, sizeof(s), stdin))\n        return 0;\n\n    while (s[i] && s[i] != '\\n')\n    {\n        if (isalnum((unsigned char)s[i]))\n            res += s[i];\n        else\n            res -= s[i];\n        i++;\n    }\n\n\tchar mouth = '|';\n\tif (res > 0) mouth = ')';\n\tif (res < 0) mouth = '(';\n\n    printf(\"%d :%c\\n\", res, mouth);\n}\n",
