      "title": "Valid Parentheses With Wildcards",
      "topics": [],
      "fastest": true,
      "reverse": true,
      "shortest": false,
      "solution": "#include <stdio.h>\n#include <string.h>\n\nint main() {\n    char s[100005];\n    scanf(\"%s\", s);\n\n    int minOpen = 0, maxOpen = 0;\n\n    for (int i = 0; s[i]; i++) {\n        if (s[i] == '(') {\n            minOpen++;\n            maxOpen++;\n        } else if (s[i] == ')') {\n            minOpen--;\n            maxOpen--;\n        } else { // '*'\n            minOpen--;      // treat as ')'\n            maxOpen++;      // treat as '('\n        }\n\n        if (maxOpen < 0) {\n            printf(\"false\\n\");\n            return 0;\n        }\n        if (minOpen < 0) minOpen = 0;\n    }\n\n    printf(minOpen == 0 ? \"true\\n\" : \"false\\n\");\n    return 0;\n}",
