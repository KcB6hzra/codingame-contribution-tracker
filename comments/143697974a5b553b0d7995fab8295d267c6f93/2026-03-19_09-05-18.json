    "content": "✅ Approved the contribution.\nComment: Nice problem!\n\nI made this solution :\n\nimport re\n\nmes = input().lower()\nreg = r\"di[^',. ]+\"\n\nmat = re.findall(reg, mes)\n\nfor mot in mat:\n    if mot not in [\"dis\", \"dit\"]:\n        reg2 = r\"[\\w]+\"\n        mat2 = re.search(reg2, mot[2:])\n        if mat2 : \n            print(mat2.group())\n            exit()\n\nprint(\"...\")",
